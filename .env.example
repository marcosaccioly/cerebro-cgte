# Cerebro CGTE -- variaveis de ambiente
# Copie para .env e preencha. NAO commite .env.

# Kanboard institucional
KANBOARD_API_URL=https://board.cefor.ifes.edu.br/jsonrpc.php
KANBOARD_API_USER=api.cgte
KANBOARD_API_TOKEN=

# Projeto principal e secundarios no Kanboard
KANBOARD_PROJETO_PRINCIPAL=47
KANBOARD_PROJETOS_SECUNDARIOS=58,60,73

# Git remote do workspace (preencher conforme infra escolhida)
# Em fevereiro de 2026 o repo aponta para github.com/marcosaccioly/cerebro-cgte.
# Quando o destino institucional GitLab Ifes estiver pronto, atualizar e remover este comentario.
GIT_REMOTE=
